{
  "parser": "@typescript-eslint/parser",
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:prettier/recommended"
  ],
  "env": {
    "browser": true,
    "node": true,
    "es2021": true,
    "jest": true
  },
  "ignorePatterns": [
    "dist/**",
    "release/**",
    "public/**",
    "*.min.js",
    "**/*.d.ts",
    "**/node_modules/**"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "overrides": [
    {
      "files": ["electron/**/*.js", "scripts/**/*.js"],
      "env": {
        "node": true,
        "browser": false
      },
      "rules": {
        "no-undef": "error"
      }
    },
    {
      "files": ["public/**/*.js", "src/**/*.ts", "src/**/*.svelte"],
      "env": {
        "browser": true,
        "worker": true,
        "node": false
      }
    }
  ],
  "rules": {
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": "warn"
  }
}
