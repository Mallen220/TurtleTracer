{
  "name": "turtle-tracer",
  "private": true,
  "version": "2.0.0",
  "main": "electron/main.js",
  "author": "Matthew Allen <FTCTurtleTracer@gmail.com>",
  "email": "FTCTurtleTracer@gmail.com",
  "license": "Modified Apache 2.0",
  "description": "A better alternative to the Pedro Pathing Visualizer",
  "type": "module",
  "scripts": {
    "fix:notice": "node scripts/generate-file-notice.js",
    "fix:headers": "node scripts/add-copyright.js",
    "version:bump": "node scripts/bump-version.js",
    "generate:types": "node scripts/generate-plugin-types.js",
    "generate:icons": "node scripts/generate-windows-icons.cjs",
    "check:tiles": "node scripts/check-tile-assets.cjs",
    "copy:icon": "node scripts/prepare-mac-icon.js",
    "build": "npm run generate:types && npm run generate:icons && npm run copy:icon && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "tests": "vitest run",
    "check": "npm run generate:types && npm run generate:icons && npm run check:tiles && svelte-check --tsconfig ./tsconfig.json && tsc -p tsconfig.node.json",
    "test:e2e": "playwright test",
    "dev": "npm run generate:types && npm run fix:headers && npm run format && npm run fix:notice && vite build && electron .",
    "start": "npm run build && electron .",
    "dist:mac": "npm run build && npm run copy:icon && electron-builder --mac --arm64 --publish=never",
    "dist:unsigned": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --arm64 --publish=never",
    "dist:all": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --linux --x64 --arm64 --publish=never && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --linux --x64 --publish=never",
    "dist:windows": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64 --publish=never",
    "dist:appx": "npm run build && electron-builder --win appx --publish=never",
    "dist:linux": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --linux --x64 --arm64 --publish=never",
    "dist:linux:x64": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --linux --x64 --publish=never",
    "dist:publish": "node scripts/publish.js",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-alias": "^6.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.8",
    "@types/jsdom": "^28.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/upng-js": "^2.1.5",
    "autoprefixer": "^10.4.27",
    "cli-progress": "^3.12.0",
    "electron": "^39.2.3",
    "electron-builder": "^24.13.3",
    "electron-installer-dmg": "^5.0.1",
    "fast-check": "^4.5.3",
    "hotkeys-js": "^3.13.15",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "sharp": "^0.34.5",
    "svelte": "^4.2.20",
    "svelte-check": "^3.8.6",
    "tailwindcss": "^3.4.9",
    "tslib": "^2.8.1",
    "vite": "^5.4.15",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@types/d3": "^7.4.3",
    "@types/diff": "^8.0.0",
    "@types/lodash": "^4.17.24",
    "canvas": "^3.2.1",
    "d3": "^7.9.0",
    "diff": "^8.0.3",
    "driver.js": "^1.4.0",
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.0",
    "get-port": "^7.1.0",
    "gif.js": "^0.2.0",
    "html2pdf.js": "^0.14.0",
    "lodash": "^4.17.23",
    "markdown-it": "^14.1.1",
    "prettier-plugin-java": "^2.8.1",
    "sass": "^1.97.3",
    "simple-git": "^3.32.3",
    "svelte-copy": "^1.4.2",
    "svelte-dnd-action": "^0.9.69",
    "svelte-highlight": "^7.9.0",
    "two.js": "^0.8.23",
    "typescript": "^5.9.3",
    "update-electron-app": "^3.1.2",
    "upng-js": "^2.1.0",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.turtletracer.visualizer",
    "productName": "Turtle Tracer",
    "asar": true,
    "asarUnpack": [
      "node_modules/electron-updater"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "artifactName": "Turtle-Tracer-${version}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "public/**/*",
      "electron/**/*",
      "plugins/**/*",
      "package.json"
    ],
    "extraResources": [
      "public/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "icon": "build/icon.png",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "target": [
        "nsis",
        "appx"
      ],
      "icon": "build/icon.png",
      "timeStampServer": ""
    },
    "appx": {
      "identityName": "PedroPathingPlus.12978EBCCDE63",
      "publisher": "CN=D17DA008-76B7-4978-BFAA-9ED056EE08B9",
      "publisherDisplayName": "Turtle Tracer",
      "applicationId": "PedroPathingPlus.12978EBCCDE63"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "perMachine": true,
      "artifactName": "Turtle-Tracer-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Development",
      "maintainer": "Matthew Allen <FTCTurtleTracer@gmail.com>",
      "executableName": "turtle-tracer",
      "artifactName": "Turtle-Tracer-${version}-${arch}.${ext}"
    },
    "appImage": {
      "artifactName": "Turtle-Tracer-${version}-${arch}.${ext}"
    },
    "fileAssociations": [
      {
        "ext": "turt",
        "name": "Turtle Tracer Project",
        "description": "Turtle Tracer Project File",
        "icon": "build/icon.png",
        "role": "Editor",
        "rank": "Owner"
      },
      {
        "ext": "pp",
        "name": "Turtle Tracer Project (Legacy .pp)",
        "description": "Legacy Turtle Tracer Project File",
        "icon": "build/icon.png",
        "role": "Editor",
        "rank": "Owner"
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "Mallen220",
      "repo": "TurtleTracer"
    }
  },
  "overrides": {
    "tar": "7.5.7",
    "esbuild": "^0.25.0"
  }
}
